# FINPAL™ SalesOS — Environment Variables Template
# Copy to .env.local and fill in your values. NEVER commit .env.local

# ── DATABASE (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/finpal?sslmode=require"

# ── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-32-char-random-string"
JWT_REFRESH_SECRET="generate-32-char-random-string"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-32-char-random-string"

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
PINECONE_API_KEY="..."
PINECONE_INDEX_NAME="finpal-rag"
PINECONE_ENVIRONMENT="gcp-starter"

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@finpal.online"

# ── REDIS (Upstash) ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# ── PAYMENTS ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PAYFAST_MERCHANT_ID="..."
PAYFAST_MERCHANT_KEY="..."

# ── SOCIAL MEDIA ─────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."
TWITTER_API_KEY="..."
TWITTER_API_SECRET="..."
FACEBOOK_APP_ID="..."
FACEBOOK_APP_SECRET="..."

# ── STORAGE (Cloudflare R2 or AWS S3) ────────────────────────────────────────
S3_BUCKET_NAME="finpal-uploads"
S3_REGION="af-south-1"
S3_ACCESS_KEY_ID="..."
S3_SECRET_ACCESS_KEY="..."

# ── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.finpal.online"
NEXT_PUBLIC_API_URL="https://api.finpal.online"
NEXT_PUBLIC_WIDGET_URL="https://widget.finpal.online"
NODE_ENV="development"
